@using CSI402.Models.Db
@model IEnumerable<LabStudent>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>UserID</th>
            <th>Password</th>
            <th>Name</th>
            <th>Last Name</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.StdId</td>
                <td>@item.StdPassword</td>
                <td>@item.StdName</td>
                <td>@item.StdLastname</td>
                <td><a asp-route-UID="@item.StdId" asp-action="Lab10" asp-controller="Home">Edit</a></td>
                <td><a onclick="return confirm('คุณแน่ใจหรือไม่ว่าต้องการลบนักเรียนคนนี้?');" asp-route-UID="@item.StdId" asp-action="Lab10D" asp-controller="Home">Delete</a></td>
            </tr>
        }
    </tbody>
</table>