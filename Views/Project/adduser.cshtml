@{Layout = "_UserLayout";}
@model CSI402.ViewModels.ProjectUserViewModel

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white text-center mb-3">
                    <h2 class="mb-0">เพิ่มผู้ใช้ใหม่</h2>
                </div>
                <div class="card-body">
                    <form method="post">
                        <div class="row">
                            <div class="col-12 col-md-6 mb-3">
                                <label for="name" class="form-label">ชื่อ</label>
                                <input type="text" class="form-control" id="name" name="Name">
                            </div>
                            <div class="col-12 col-md-6 mb-3">
                                <label for="lastname" class="form-label">นามสกุล</label>
                                <input type="text" class="form-control" id="lastname" name="Lastname">
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-6 mb-3">
                                <label for="tel" class="form-label">โทรศัพท์</label>
                                <input type="tel" class="form-control" id="tel" name="Tel" placeholder="08x-xxx-xxxx">
                            </div>
                        </div>
                        <div><label for="email" class="form-label">อีเมล</label>
                            <input type="email" class="form-control" id="email" name="Email">
                        </div>
                        <div><label for="password" class="form-label">รหัสผ่าน</label>
                            <input type="password" class="form-control" id="password" name="Password">
                        </div>
                        <div><label for="address" class="form-label">ที่อยู่</label>
                            <input type="text" class="form-control" id="address" name="Address">
                        </div>
                        <div><label for="role" class="form-label">บทบาท</label>
                            <select class="form-select" id="role" name="Role">
                                <option value="User">User</option>
                                <option value="Admin">Admin</option>
                            </select>
                        <div class="d-flex justify-content-end mt-4">
                            <a asp-controller="Project" asp-action="UserList" class="btn btn-secondary me-2">ยกเลิก</a>
                            <button type="submit" class="btn btn-primary"><a asp-controller="Project" asp-action="Userlist" style="color: aliceblue; text-decoration: none;">เพิ่มผู้ใช้</a></button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
