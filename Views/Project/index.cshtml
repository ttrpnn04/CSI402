@{ Layout = "_UserLayout"; }

<style>
    .card-header { font-weight: 600; text-align: center; }
</style>
    <div class="row g-4">
        <div class="col-12">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-primary text-white">
                    <span>Login Users</span>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Username</th>
                                    <th>Password</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var loginUser in ViewBag.LoginUsers)
                                {
                                    <tr>
                                        <td>@loginUser.Username</td>
                                        <td>@loginUser.Password</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

    <div class="col-12">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-primary text-white">
                    <span>Registered Users</span>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Username</th>
                                    <th>Name</th>
                                    <th>Lastname</th>
                                    <th>Age</th>
                                    <th>Tel.</th>
                                    <th>Email</th>
                                    <th>Password</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var registerUser in ViewBag.RegisterUsers)
                                {
                                    <tr>
                                        <td>@registerUser.Username</td>
                                        <td>@registerUser.Name</td>
                                        <td>@registerUser.Lastname</td>
                                        <td>@registerUser.Age</td>
                                        <td>@registerUser.Tel</td>
                                        <td>@registerUser.Email</td>
                                        <td>@registerUser.Password</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>