@{Layout = "_UserLayout";}
<div>
    <h1>UserList</h1>
    <div>
        <table class="table-bordered table mt-3">
            <thead class="table-dark">
                <tr>
                    <th>Username</th>
                    <th>Lastname</th>
                    <th>Age</th>
                    <th>Email</th>
                    <th>Tel</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in ViewBag.Users)
                {
                    <tr>
                        <td>@user.Username</td>
                        <td>@user.LastName</td>
                        <td>@user.Age</td>
                        <td>@user.Email</td>
                        <td>@user.Tel</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>