@{ Layout = "_UserLayout"; }
@using CSI402.Models.Db>
@model IEnumerable<User>

<div class="container py-4">
    <div class="userlist-header text-center">
        <h2 class="mb-0">รายชื่อผู้ใช้งาน</h2>
        <small class="text-white-50">รายการผู้ใช้ทั้งหมด</small>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm userlist-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3 userlist-toolbar">
                        <div>
                            <a asp-controller="Project" asp-action="AddUser" class="btn btn-sm btn-primary me-2">เพิ่มผู้ใช้</a>
                        </div>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-striped table-hover userlist-table mb-0">
                            <thead>
                                <tr>
                                    <th>Username</th>
                                    <th>Fullname</th>
                                    <th>Email</th>
                                    <th>Tel</th>
                                    <th>Address</th>   
                                    <th>Role</th> 
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var u in Model)
                                {
                                    <tr>
                                        <td>@u.UserName</td>
                                        <td>@u.Fullname</td>
                                        <td>@u.Email</td>
                                        <td>@u.Phone</td>
                                        <td>@u.Address</td>
                                        <td>@u.Role</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>